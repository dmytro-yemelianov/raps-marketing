---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Book a Demo" description="See Rapsody in action. Schedule a personalized demo." section="rapsody">
  <div class="content-container py-16">
    <div class="max-w-2xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-4">
        <span class="bg-gradient-to-r from-raps-purple to-raps-blue bg-clip-text text-transparent">Book a Demo</span>
      </h1>
      <p class="text-xl text-gray-600 text-center mb-12">
        See how Rapsody can transform your Autodesk Construction Cloud operations.
      </p>

      <form id="demo-form" class="space-y-6">
        <div>
          <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
          <input type="text" id="name" name="name" required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-raps-purple focus:border-transparent outline-none" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Work Email</label>
          <input type="email" id="email" name="email" required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-raps-purple focus:border-transparent outline-none" />
        </div>
        <div>
          <label for="company" class="block text-sm font-medium text-gray-700 mb-1">Company</label>
          <input type="text" id="company" name="company" required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-raps-purple focus:border-transparent outline-none" />
        </div>
        <div>
          <label for="projects" class="block text-sm font-medium text-gray-700 mb-1">How many ACC projects do you manage?</label>
          <select id="projects" name="projects"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-raps-purple focus:border-transparent outline-none bg-white">
            <option value="">Select...</option>
            <option value="1-50">1-50</option>
            <option value="51-200">51-200</option>
            <option value="201-500">201-500</option>
            <option value="500+">500+</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">What challenges are you facing? (optional)</label>
          <textarea id="message" name="message" rows="4"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-raps-purple focus:border-transparent outline-none"></textarea>
        </div>
        <button type="submit"
          class="w-full btn bg-gradient-to-r from-raps-purple to-raps-blue text-white text-lg py-3 rounded-lg font-medium transition-all hover:shadow-lg">
          Request Demo
        </button>
      </form>

      <div id="demo-success" class="hidden text-center py-12">
        <div class="text-6xl mb-4">🎉</div>
        <h2 class="text-2xl font-bold mb-2">Demo Requested</h2>
        <p class="text-gray-600 mb-6">We'll be in touch within 24 hours to schedule your demo.</p>
        <a href="/rapsody" class="btn btn-secondary">Back to Rapsody</a>
      </div>
    </div>
  </div>

  <script>
    const form = document.getElementById('demo-form') as HTMLFormElement;
    const success = document.getElementById('demo-success')!;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form));
      try {
        await fetch('/api/demo', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } catch {
        // Still show success -- form data is also captured by analytics
      }
      form.classList.add('hidden');
      success.classList.remove('hidden');
    });
  </script>
</BaseLayout>

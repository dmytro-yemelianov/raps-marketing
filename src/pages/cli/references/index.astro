---
import CLILayout from '../../../layouts/CLILayout.astro';
import { getCollection } from 'astro:content';

const references = await getCollection('references');
---

<CLILayout title="References" description="API references, error codes, and OAuth scope documentation.">
  <div class="hero-pattern py-12">
    <div class="content-container">
      <h1 class="text-4xl md:text-5xl font-bold text-center mb-4">
        <span class="gradient-text">References</span>
      </h1>
      <p class="text-xl text-gray-600 text-center max-w-3xl mx-auto">
        Quick-lookup references for APS development
      </p>
    </div>
  </div>

  <div class="content-container py-12">
    <div class="grid md:grid-cols-2 gap-6">
      {references.map((ref) => (
        <a href={`/cli/references/${ref.slug}`} class="card p-6 hover:shadow-xl transition-all group">
          <div class="flex items-center justify-between mb-4">
            <span class="text-xs bg-blue-50 text-blue-700 px-2 py-1 rounded capitalize">{ref.data.category}</span>
            <span class={`text-xs px-2 py-1 rounded ${
              ref.data.completeness === 'complete' ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700'
            }`}>
              {ref.data.completeness}
            </span>
          </div>
          <h3 class="text-xl font-semibold mb-2 group-hover:text-raps-blue transition">{ref.data.title}</h3>
          <p class="text-gray-600">{ref.data.description}</p>
        </a>
      ))}
    </div>

    {references.length === 0 && (
      <div class="text-center py-12">
        <p class="text-gray-500 text-lg">References coming soon.</p>
      </div>
    )}
  </div>
</CLILayout>

---
import CLILayout from '../../../layouts/CLILayout.astro';
import { getEntry } from 'astro:content';

const guide = await getEntry('guides', 'which-api-do-i-need');
const { Content } = await guide.render();
---

<CLILayout title="API Decision Tree" description="Find the right APS API for your use case.">
  <article class="content-container py-12">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-center text-sm text-gray-500 mb-4">
        <a href="/cli/learn" class="hover:text-raps-blue">Learn</a>
        <span class="mx-2">/</span>
        <span>API Decision Tree</span>
      </div>
      <h1 class="text-4xl font-bold mb-6">{guide.data.title}</h1>
      <div class="prose prose-lg prose-gray max-w-none">
        <Content />
      </div>
      <nav class="mt-12 pt-8 border-t border-gray-200">
        <a href="/cli/learn" class="btn btn-secondary">Back to Learn</a>
      </nav>
    </div>
  </article>
</CLILayout>

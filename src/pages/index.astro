---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="APS Automation"
  description="Open-source CLI and enterprise bulk operations for Autodesk Platform Services."
>
  <div class="flex flex-col md:flex-row min-h-[calc(100vh-4rem)]">
    <!-- Left Panel: RAPS CLI (OSS) -->
    <div class="flex-1 flex items-center justify-center p-8 md:p-12 bg-white">
      <div class="max-w-md text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text">RAPS CLI</span>
        </h1>
        <p class="text-lg text-gray-600 mb-6">
          Open-source APS automation. 51+ tools. MIT licensed.
        </p>
        <div class="bg-gray-900 rounded-lg p-4 text-left mb-8">
          <code class="text-green-400 text-sm">
            <span class="text-gray-500">$</span> npm install -g @rapscli/cli<br/>
            <span class="text-gray-500">$</span> raps auth login<br/>
            <span class="text-gray-500">$</span> raps oss upload model.rvt --translate
          </code>
        </div>
        <a href="/cli" class="btn btn-primary text-lg px-8 py-3 inline-block">
          Get Started
        </a>
        <div class="mt-4">
          <a
            href="https://github.com/autodesk-platform-services/raps"
            class="inline-flex items-center text-sm text-gray-500 hover:text-raps-blue transition"
            target="_blank"
            rel="noopener"
          >
            <svg class="w-4 h-4 mr-1" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
            Star on GitHub
          </a>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="hidden md:block w-px bg-gray-200"></div>
    <div class="md:hidden h-px bg-gray-200 mx-8"></div>

    <!-- Right Panel: Rapsody (Enterprise) -->
    <div class="flex-1 flex items-center justify-center p-8 md:p-12 bg-gradient-to-br from-gray-50 to-white">
      <div class="max-w-md text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="bg-gradient-to-r from-raps-purple to-raps-blue bg-clip-text text-transparent">Rapsody</span>
        </h1>
        <p class="text-lg text-gray-600 mb-6">
          Bulk operations across thousands of projects. Safe. Fast. Auditable.
        </p>
        <div class="grid grid-cols-3 gap-4 mb-8">
          <div class="bg-white rounded-lg p-3 shadow-sm">
            <div class="text-2xl font-bold text-raps-purple">630x</div>
            <div class="text-xs text-gray-500">Faster</div>
          </div>
          <div class="bg-white rounded-lg p-3 shadow-sm">
            <div class="text-2xl font-bold text-raps-purple">1,795</div>
            <div class="text-xs text-gray-500">Projects</div>
          </div>
          <div class="bg-white rounded-lg p-3 shadow-sm">
            <div class="text-2xl font-bold text-raps-purple">&lt;4 min</div>
            <div class="text-xs text-gray-500">Execution</div>
          </div>
        </div>
        <a href="/rapsody" class="btn bg-gradient-to-r from-raps-purple to-raps-blue text-white hover:shadow-lg text-lg px-8 py-3 inline-block rounded-lg font-medium transition-all">
          See How It Works
        </a>
        <div class="mt-4">
          <a href="/survey" class="text-sm text-gray-500 hover:text-raps-purple transition">
            Take the AEC Automation Survey
          </a>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

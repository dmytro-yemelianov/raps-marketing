---
const currentPath = Astro.url.pathname;
const isCliSection = currentPath.startsWith('/cli');
const isRapsodySection = currentPath.startsWith('/rapsody');
---

<nav class="sticky top-0 z-50 bg-white/95 backdrop-blur border-b border-gray-200">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      <div class="flex items-center">
        <a href="/" class="flex items-center space-x-2">
          <span class="text-2xl font-bold bg-gradient-to-r from-raps-blue to-raps-purple bg-clip-text text-transparent">
            RAPS
          </span>
        </a>
      </div>
      <nav class="hidden md:flex items-center space-x-6">
        <a
          href="/cli"
          class:list={[
            'font-medium transition',
            isCliSection ? 'text-raps-blue' : 'text-gray-700 hover:text-raps-blue',
          ]}
        >
          RAPS CLI
        </a>
        <a
          href="/rapsody"
          class:list={[
            'font-medium transition',
            isRapsodySection ? 'text-raps-purple' : 'text-gray-700 hover:text-raps-purple',
          ]}
        >
          Rapsody
        </a>
        <a href="/survey" class="text-gray-700 hover:text-raps-blue font-medium transition">
          Survey
        </a>
        <a
          href="https://github.com/autodesk-platform-services/raps"
          class="text-gray-700 hover:text-raps-blue transition flex items-center"
          target="_blank"
          rel="noopener"
        >
          GitHub
          <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </nav>
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-gray-100">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <!-- Mobile menu -->
    <div id="mobile-menu" class="hidden md:hidden pb-4">
      <a href="/cli" class="block py-2 text-gray-700 hover:text-raps-blue font-medium">RAPS CLI</a>
      <a href="/rapsody" class="block py-2 text-gray-700 hover:text-raps-purple font-medium">Rapsody</a>
      <a href="/survey" class="block py-2 text-gray-700 hover:text-raps-blue font-medium">Survey</a>
      <a href="https://github.com/autodesk-platform-services/raps" class="block py-2 text-gray-700 hover:text-raps-blue font-medium" target="_blank" rel="noopener">GitHub</a>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
